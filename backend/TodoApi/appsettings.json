{
  "ConnectionStrings": {
    "TodoDb": "Data Source=todos.db"
  },
  "Jwt": {
    "Secret": "replace-with-a-long-random-secret-at-least-32-characters",
    "Issuer": "TodoApi"
  },
  "Vapid": {
    "Subject": "mailto:replace-with-real-admin-email@example.com",
    "PublicKey": "REPLACE_WITH_VAPID_PUBLIC_KEY_FOR_PRODUCTION",
    "PrivateKey": "REPLACE_WITH_VAPID_PRIVATE_KEY_FOR_PRODUCTION"
  },
  "FileStoragePath": "./uploads",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
